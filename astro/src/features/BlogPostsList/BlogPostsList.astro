---
import type { BlogPost } from '../../utils/getPosts';
import { getBlogPostLink } from '../../utils/links';
import PostInfo from '../../components/Post/PostInfo.astro';
import Notice from '../../components/Notice.astro';
import { tags } from '../../definitions';
import { labelsMap, type Labels } from '../../components/Post';

type Props = {
	tag?: {
		name: string;
	};
	posts: BlogPost[];
};

const { posts, tag } = Astro.props;
---

<main>
	<section>
		{
			tag && (
				<Notice>
					Posts with tag <b>{tag.name}</b>{' '}
					{tags[tag.name] ? `- ${tags[tag.name]}` : ''}
				</Notice>
			)
		}

		<ul>
			{
				posts.map((post) => (
					<li>
						<div class="head">
							<h4 class="title">
								<a href={getBlogPostLink(post.id)}>{post.data.title}</a>
							</h4>

							<div class="meta">
								<PostInfo
									date={post.data.date}
									readingTime={post.readingTime}
									labels={
										post.data.tags.filter(
											(tag) => tag in labelsMap,
										) as Labels[]
									}
									links={post.data.links ?? []}
								/>
							</div>
						</div>

						<div class="body">
							<span class="description">{post.previewText}</span>
							{post.data.image && (
								<a
									href={getBlogPostLink(post.id)}
									title="Click to read more"
									class="cover-image"
								>
									<img
										src={post.data.image.src}
										width={post.data.image.width}
										height={post.data.image.height}
									/>
								</a>
							)}
						</div>

						<div class="links">
							<a href={getBlogPostLink(post.id)}>Read More</a>
						</div>
					</li>
				))
			}
		</ul>

		<slot name="pagination" />
	</section>
</main>

<style>
	section {
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	ul {
		display: flex;
		flex-direction: column;
		gap: 4rem;

		margin: 0;
		padding: 0;
	}

	li {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.head {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.title a {
		color: #333;
		text-decoration: none;

		&:hover {
			text-decoration: underline;
		}
	}

	.links a {
		font-size: 0.9em;
		color: gray;
	}

	.meta {
		font-size: 0.8em;
		color: #626262;
	}

	.body {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.cover-image {
		display: flex;
		width: 100%;
		height: fit-content;
		border-radius: 8px;
		overflow: hidden;
		flex-shrink: 0;

		img {
			height: fit-content;
			object-fit: cover;
		}
	}

	@media (width >= 800px) {
		.body {
			flex-direction: row;
		}
		.cover-image {
			width: 30%;
		}
	}
</style>
